# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Google OAuth credentials (from Google Cloud Console > Credentials)
GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret-here

# The URL your app runs on (change for production)
APP_URL=http://localhost:3000

# A long random string used to encrypt sessions (make up something random)
SESSION_SECRET=change-this-to-a-long-random-string-like-abc123xyz789

# Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here
